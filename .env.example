# ──────────────────────────────────────────────
# YOUTUBE AUTOMATION AGENT — Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# ── AI (FREE) ───────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ── VOICE (FREE 10k chars/month) ────────────────
# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# Voice ID — Adam (confident male US accent):
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── STOCK FOOTAGE (FREE 200 req/hour) ───────────
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# ── YOUTUBE OAUTH2 ──────────────────────────────
# Setup steps:
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Run: node scripts/get_youtube_token.js
# 5. Copy the refresh_token here
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# ── LINKEDIN (OPTIONAL) ─────────────────────────
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID_HERE

# ── DISCORD NOTIFICATIONS ───────────────────────
# Create webhook in your Discord server → Channel Settings → Integrations
DISCORD_WEBHOOK_YOUTUBE=https://discord.com/api/webhooks/xxx/yyy

# ── PIPELINE SETTINGS ───────────────────────────
MODE=short          # short | longform | recap
DRY_RUN=false       # true = skip upload (for testing)
RECAP_DATA=         # Weekly trading/dev recap data (for recap mode)
